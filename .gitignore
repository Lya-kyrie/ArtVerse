# ========================================
# Only allow ArtVerse/ and frontend/
# All other root-level files are excluded
# ========================================
/*
!/ArtVerse
!/frontend
!.gitignore

.env

.idea/
*.iml

target/
dist/
node_modules/

ArtVerse/target/
ArtVerse/.idea/
ArtVerse/.agentscope/
frontend/.playwright-cli/

.DS_Store
Thumbs.db
